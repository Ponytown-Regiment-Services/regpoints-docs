<div class="credit-grid">
  <slot />
</div>

<style>
  .credit-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .credit-grid > :global(*) {
    width: 100%;
    height: 100%;
    margin: 0 !important;
  }

  @media (max-width: 600px) {
    .credit-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 400px) {
    .credit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
